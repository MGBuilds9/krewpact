# === Supabase ===
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, bypasses RLS. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=
# Direct database URL (for migrations/scripts only — NOT for Vercel serverless)
SUPABASE_DB_URL=

# === Clerk ===
# Get these from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk Third-Party Auth / Supabase integration must be enabled in Clerk.
# KrewPact claims are sourced from Clerk user metadata:
#   krewpact_user_id, krewpact_org_id, division_ids, role_keys
# Webhook signing secret for Clerk → KrewPact webhook verification
CLERK_WEBHOOK_SECRET=
# Root domain for cross-subdomain session sharing
NEXT_PUBLIC_CLERK_DOMAIN=

# === ERPNext (via Cloudflare Tunnel) ===
# ERPNext base URL — Cloudflare Tunnel endpoint (e.g., https://erp.yourdomain.com)
ERPNEXT_BASE_URL=
# ERPNext API credentials — generate at ERPNext → Settings → API Access
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
# Webhook secret for ERPNext → KrewPact webhook verification
ERPNEXT_WEBHOOK_SECRET=
# ERPNext accounting accounts for inventory sync (optional — inventory cost journals disabled when missing)
# ERPNEXT_COGS_ACCOUNT=Cost of Goods Sold - MDM
# ERPNEXT_STOCK_ACCOUNT=Stock In Hand - MDM
# ERPNEXT_WAREHOUSE=Main Warehouse - MDM

# === Upstash QStash (job queue) ===
# Get these from: https://console.upstash.com → QStash → Details
QSTASH_URL=
QSTASH_TOKEN=
# Signing keys for verifying incoming QStash webhooks
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# === Upstash Redis (rate limiting) ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === BoldSign (e-sign) ===
# Get these from: https://app.boldsign.com → API → Keys
BOLDSIGN_API_KEY=
BOLDSIGN_BASE_URL=https://api.boldsign.com
# Webhook secret for BoldSign → KrewPact webhook verification
BOLDSIGN_WEBHOOK_SECRET=

# === Resend (email) ===
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# === App ===
# Public URL of the app (used for webhooks, email links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Mobile internal-beta public config
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Signing secret for internal webhook verification
WEBHOOK_SIGNING_SECRET=
# Secret for authenticating Vercel Cron jobs
CRON_SECRET=
# Ops alert email recipient
ALERT_EMAIL=
# Demo mode flag (disables destructive actions in UI)
# NEXT_PUBLIC_DEMO_MODE=false
# Logging verbosity (debug|info|warn|error)
# LOG_LEVEL=info

# === Sentry (error tracking) ===
# Get these from: https://sentry.io → Project Settings → Client Keys (DSN)
# SENTRY_DSN is used server-side; NEXT_PUBLIC_SENTRY_DSN is used client-side.
# Both should be set to the same DSN value.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Required for production: source map uploads + release tracking
# SENTRY_AUTH_TOKEN — https://sentry.io → Auth Tokens
# SENTRY_ORG — your Sentry org slug
# SENTRY_PROJECT — your Sentry project slug
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# === AI / LLM (optional — AI features disabled when AI_ENABLED=false or keys missing) ===
# AI_ENABLED=true
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# GEMINI_API_KEY=  # Alias for Google Generative AI — set same value

# === AI Takeoff Engine (optional — estimate takeoff disabled when missing) ===
# TAKEOFF_ENGINE_URL=
# TAKEOFF_ENGINE_TOKEN=

# === Lead Enrichment APIs (optional — enrichment features disabled when missing) ===
# APOLLO_API_KEY=
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# TAVILY_RESEARCH_API_KEY=  # Deep research endpoint (distinct from TAVILY_API_KEY)
# GOOGLE_MAPS_API_KEY=

# === Email Sender (optional — defaults to MDM domain) ===
# RESEND_FROM_EMAIL=Your Company <noreply@updates.yourdomain.com>

# === Company Metadata (optional — used in proposals, defaults below) ===
# COMPANY_NAME=Your Company
# COMPANY_ADDRESS=123 Main St, Suite 100, City, Province A1B 2C3
# COMPANY_PHONE=(555) 555-0100
# COMPANY_EMAIL=info@yourdomain.com

# === Email Domain Allowlist (optional — controls who can log in) ===
# ALLOWED_DOMAINS=yourdomain.com,subsidiary.com

# === Seed Scripts (scripts/seed-*.ts only — never used in app) ===
# Clerk user ID for the production admin user (create manually in Clerk dashboard first)
# Used by: npx tsx scripts/seed-test-users.ts --admin-only
# SEED_ADMIN_CLERK_ID=user_xxxxxxxxxxxxxxxxxxxx
# SEED_ADMIN_EMAIL=admin@yourdomain.com
