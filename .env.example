# === Supabase ===
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, bypasses RLS. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=
# Direct database URL (for migrations/scripts only — NOT for Vercel serverless)
SUPABASE_DB_URL=

# === Clerk ===
# Get these from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret for Clerk → KrewPact webhook verification
CLERK_WEBHOOK_SECRET=
# Root domain for cross-subdomain session sharing
NEXT_PUBLIC_CLERK_DOMAIN=mdmgroupinc.ca

# === ERPNext (via Cloudflare Tunnel) ===
# ERPNext base URL — Cloudflare Tunnel endpoint (e.g., https://erp.mdmgroupinc.ca)
ERPNEXT_BASE_URL=
# ERPNext API credentials — generate at ERPNext → Settings → API Access
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
# Webhook secret for ERPNext → KrewPact webhook verification
ERPNEXT_WEBHOOK_SECRET=

# === Upstash QStash (job queue) ===
# Get these from: https://console.upstash.com → QStash → Details
QSTASH_URL=
QSTASH_TOKEN=
# Signing keys for verifying incoming QStash webhooks
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# === Upstash Redis (rate limiting) ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === BoldSign (e-sign) ===
# Get these from: https://app.boldsign.com → API → Keys
BOLDSIGN_API_KEY=
BOLDSIGN_API_BASE_URL=https://api.boldsign.com
# Webhook secret for BoldSign → KrewPact webhook verification
BOLDSIGN_WEBHOOK_SECRET=

# === Resend (email) ===
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# === App ===
# Public URL of the app (used for webhooks, email links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Signing secret for internal webhook verification
WEBHOOK_SIGNING_SECRET=
# Secret for authenticating Vercel Cron jobs
CRON_SECRET=

# === Sentry (error tracking) ===
# Get these from: https://sentry.io → Project Settings → Client Keys (DSN)
# SENTRY_DSN is used server-side; NEXT_PUBLIC_SENTRY_DSN is used client-side.
# Both should be set to the same DSN value.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional: for source map uploads (https://sentry.io → Auth Tokens)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# === Lead Enrichment APIs (optional — enrichment features disabled when missing) ===
# APOLLO_API_KEY=
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# GOOGLE_MAPS_API_KEY=

# === Email Sender (optional — defaults to MDM domain) ===
# RESEND_FROM_EMAIL=MDM Group Inc. <noreply@updates.mdmgroupinc.ca>

# === Company Metadata (optional — used in proposals, defaults below) ===
# COMPANY_NAME=MDM Group Inc.
# COMPANY_ADDRESS=2233 Argentia Road, Suite 302, Mississauga, ON L5N 2X7
# COMPANY_PHONE=(905) 542-2950
# COMPANY_EMAIL=info@mdmgroupinc.ca

# === Email Domain Allowlist (optional — controls who can log in) ===
# ALLOWED_DOMAINS=mdmgroupinc.ca,mdmcontracting.ca

# === Demo Mode (optional) ===
# Set to "true" to run without external services (Supabase, Clerk, ERPNext).
# Uses mock data and demo auth. Good for local UI development.
NEXT_PUBLIC_DEMO_MODE=false
